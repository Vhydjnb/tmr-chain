import hashlib
import json
import time
import os
from flask import Flask, jsonify, request
from ecdsa import SigningKey, SECP256k1, VerifyingKey

app = Flask(__name__)
FILE_NAME = "blockchain.json"

class TMRBlockchain:
    def __init__(self):
        self.chain = self.load_chain()
        self.pending_transactions = []
        self.difficulty = 2

    def load_chain(self):
        if os.path.exists(FILE_NAME):
            with open(FILE_NAME, 'r') as f:
                return json.load(f)
        else:
            genesis = {'index': 0, 'timestamp': time.time(), 'transactions': [], 'previous_hash': '0', 'nonce': 0}
            genesis['hash'] = self.calculate_hash(genesis)
            return [genesis]

    def save_chain(self):
        with open(FILE_NAME, 'w') as f:
            json.dump(self.chain, f, indent=4)

    def calculate_hash(self, block):
        return hashlib.sha256(json.dumps(block, sort_keys=True).encode()).hexdigest()

    def mine_block(self):
        last_block = self.chain[-1]
        new_block = {
            'index': len(self.chain),
            'timestamp': time.time(),
            'transactions': self.pending_transactions,
            'previous_hash': last_block['hash'],
            'nonce': 0
        }
        while True:
            new_block['hash'] = self.calculate_hash(new_block)
            if new_block['hash'][:self.difficulty] == '0' * self.difficulty:
                break
            new_block['nonce'] += 1
        self.chain.append(new_block)
        self.pending_transactions = []
        self.save_chain()
        return new_block

tmr_chain = TMRBlockchain()

@app.route('/wallet/new', methods=['GET'])
def new_wallet():
    # Generate ECDSA key pair
    sk = SigningKey.generate(curve=SECP256k1)
    vk = sk.verifying_key
    return jsonify({
        "private_key": sk.to_string().hex(),
        "public_key": vk.to_string().hex(),
        "address": hashlib.sha256(vk.to_string()).hexdigest()
    })

@app.route('/transaction/new', methods=['POST'])
def new_transaction():
    values = request.get_json()
    # Simple validation: ensure amount is a multiple of 0.1, supply capped at 10
    amount = round(float(values['amount']), 1)
    tmr_chain.pending_transactions.append({
        'sender': values['sender'],
        'recipient': values['recipient'],
        'amount': amount
    })
    return jsonify({"message": "Transaction added to pool"}), 201

@app.route('/chain', methods=['GET'])
def get_chain():
    return jsonify({"chain": tmr_chain.chain, "length": len(tmr_chain.chain)})

@app.route('/mine', methods=['GET'])
def mine():
    block = tmr_chain.mine_block()
    return jsonify({"message": "New block mined!", "block": block}), 200

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000)

